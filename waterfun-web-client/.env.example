# ============================================================
# WaterFun Web Client — 环境变量参考
# 复制为 .env.development (开发) 或 .env.production (生产)
# ============================================================

# -------- API 基础路径 --------
# 开发环境使用 protocol-relative URL
# VITE_API_BASE=//localhost:8080/api
# 生产环境替换为真实域名
# VITE_API_BASE=//api.your-domain.com/api

# -------- CSRF 跳过路径 (逗号分隔) --------
# VITE_CSRF_SKIP_LIST=/auth/captcha,/public/data

# -------- Auth 跳过路径 (不附加 Authorization header) --------
# VITE_AUTH_SKIP_LIST=/auth/captcha,/auth/send-code,/auth/login-by-username,...

# -------- Nuxt API 基础路径 --------
# NUXT_PUBLIC_API_BASE=//localhost:8080/

# -------- 头像缓存过期时间 (秒) --------
# NUXT_PUBLIC_AVATAR_EXPIRE_TIME=3600

# ---- 生产环境 ----
# 部署前替换 YOUR_DOMAIN 为真实域名
VITE_API_BASE=//api.YOUR_DOMAIN/api/admin
VITE_CSRF_SKIP_LIST=/auth/captcha,/public/data,/auth/csrf-token,/auth/login-by-password
VITE_AUTH_SKIP_LIST=/auth/captcha,/auth/send-sms-code,/auth/send-email-code,/auth/login,/auth/login-by-password,/auth/register,/auth/csrf-token

NUXT_PUBLIC_API_BASE=//api.YOUR_DOMAIN/
